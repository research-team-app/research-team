# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# When running locally (RUN_LOCAL=true) these are loaded from this file.
# In AWS Glue they are passed as job parameters instead.

# Set to "true" to run locally with dotenv instead of Glue job parameters
RUN_LOCAL=true

# Grants.gov search API endpoint
GRANTS_API_URL=https://api.grants.gov/v1/api/search2

# Aurora DSQL endpoint hostname
DB_DSN=your-cluster-id.dsql.us-east-1.on.aws

# Database table names
DB_TABLE=grants
SUMMARY_TABLE=grants_summary

# How many grants to fetch per page and max pages to paginate
GRANTS_ROWS=100
GRANTS_MAX_PAGES=30

# Bedrock embedding model ID
EMBED_MODEL=cohere.embed-v4:0

# S3 Vectors bucket and index
VECTOR_BUCKET=grants-vectors
VECTOR_INDEX=grants-vectors-index
