# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# Three connection modes (set USE_LOCAL_DATABASE accordingly):
#
#   1. Docker / public contributor  — USE_LOCAL_DATABASE=true, DATABASE_URL=postgres
#      Spins up a local Postgres via docker compose. No AWS account needed.
#
#   2. Local dev with AWS access    — USE_LOCAL_DATABASE=false, DATABASE_URL=<dsql-host>
#      Connects directly to Aurora DSQL using your ~/.aws credentials.
#      Run the API with: uv run uvicorn main:app --reload
#
#   3. Production (Lambda)          — USE_LOCAL_DATABASE=false, DATABASE_URL=<dsql-host>
#      Same DSQL path; boto3 picks up the Lambda execution role automatically.

# ── Database ──────────────────────────────────────────────────────────────────

# Host of the PostgreSQL / Aurora DSQL instance.
# Docker mode: use "postgres" (the compose service name).
# DSQL mode:   use your cluster hostname from the AWS console.
DATABASE_URL=postgres

# Set to "true" to connect to a plain Postgres instead of AWS Aurora DSQL
USE_LOCAL_DATABASE=true

# Password used in local/Docker mode (ignored when USE_LOCAL_DATABASE=false)
DATABASE_PASSWORD=postgres

# ── AWS ───────────────────────────────────────────────────────────────────────
# These are only needed when USE_LOCAL_DATABASE=false (production / staging).

AWS_REGION=us-east-1
COGNITO_REGION=us-east-1

# Leave empty to disable JWT verification (fine for local development)
COGNITO_USER_POOL_ID=

# ── Internal auth ─────────────────────────────────────────────────────────────

# Shared secret for service-to-service tokens (Glue, Lambda, cron)
# Any non-empty string works locally
INTERNAL_API_KEY=local-dev-secret

# ── Admin access ──────────────────────────────────────────────────────────────

# Comma-separated Cognito user sub IDs with admin access (not needed locally)
ADMIN_SUBS=

# ── Docs ──────────────────────────────────────────────────────────────────────

# Set to "true" to expose /docs and /redoc publicly (local development only).
# In production leave unset or "false" — use /admin/docs?token=<bearer_token> instead.
IS_LOCAL=true
